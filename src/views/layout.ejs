<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title><%= title %> | Internet Solutions</title>
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="app-container">
        <!-- Universal Top Navigation -->
        <header class="top-nav">
            <a href="/portal" class="top-nav-logo">
                <i class="fas fa-bolt"></i>
                <span>Solutions</span>
            </a>
            <% if (locals.session && locals.session.userId) { %>
                <a href="/logout" style="color: var(--danger); font-size: 1.2rem;"><i class="fas fa-power-off"></i></a>
            <% } else { %>
                <a href="/login" style="color: var(--primary); font-weight: 800; font-size: 0.8rem; letter-spacing: 1px;">LOGIN</a>
            <% } %>
        </header>

        <!-- Main Scrollable Content Area -->
        <div class="scroll-area no-scrollbar">
            <% if (locals.error) { %>
                <div class="alert alert-danger">
                    <i class="fas fa-circle-exclamation"></i> <%= error %>
                </div>
            <% } %>
            <% if (locals.notice) { %>
                <div class="alert alert-info">
                    <i class="fas fa-circle-info"></i> <%= notice %>
                </div>
            <% } %>

            <%- body %>
        </div>

        <!-- Universal Bottom Navigation -->
        <nav class="bottom-nav">
            <ul class="bottom-nav-menu">
                <li class="bottom-nav-item <%= title === 'Welcome to Our Captive Portal' ? 'active' : '' %>">
                    <a href="/portal"><i class="fas fa-home-alt"></i><span>HOME</span></a>
                </li>
                <li class="bottom-nav-item <%= title === 'User Login' || title === 'Register' || title === 'Account Settings' ? 'active' : '' %>">
                    <a href="/settings"><i class="fas fa-user-circle"></i><span>PROFILE</span></a>
                </li>
                <li class="bottom-nav-item <%= title === 'User Dashboard' ? 'active' : '' %>">
                    <a href="/dashboard"><i class="fas fa-grid-2"></i><span>STATS</span></a>
                </li>
                <% if (locals.session && locals.session.role === 'admin') { %>
                <li class="bottom-nav-item <%= title.includes('Admin') ? 'active' : '' %>">
                    <a href="/admin"><i class="fas fa-shield-bolt"></i><span>ADMIN</span></a>
                </li>
                <% } %>
            </ul>
        </nav>
    </div>

    <input type="hidden" id="paystack-public-key" value="<%= locals.PAYSTACK_PUBLIC_KEY %>">

    <script src="https://js.paystack.co/v1/inline.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>
