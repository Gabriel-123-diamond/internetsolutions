<section class="portal-hero">
    <h1>Welcome to Internet Solutions</h1>
    <p>Please enter your voucher code to start browsing.</p>
</section>

<section class="login-section">
    <div class="card">
        <h2 style="margin-bottom: 0.5rem;"><i class="fas fa-key"></i> Voucher Login</h2>
        <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1.5rem;">Enter your 6-character code below</p>
        <form action="/login/voucher" method="POST">
            <div class="form-group">
                <input type="text" id="voucherCode" name="voucherCode" placeholder="ABCDEF" maxlength="6" required style="text-align: center; font-weight: 800; font-size: 1.5rem; letter-spacing: 4px;">
            </div>
            <button type="submit" class="btn btn-primary btn-block">CONNECT INTERNET</button>
        </form>
        <p style="margin-top: 1.5rem; font-size: 0.9rem;">No voucher? <a href="#plansGrid" style="color: var(--accent); font-weight: 700;">Purchase one below</a></p>
    </div>
</section>

<section class="plans-section" id="plansGrid">
    <div style="text-align: center; margin-bottom: 2rem;">
        <h2 class="text-gradient" style="margin-bottom: 0.25rem;">Available Plans</h2>
        <p style="color: var(--text-muted); font-size: 0.9rem;">Instant activation after payment</p>
    </div>
    
    <div class="plans-grid">
        <% plans.forEach(plan => { %>
            <div class="plan-card card">
                <h3><%= plan.name %></h3>
                <div class="price">₦<%= parseFloat(plan.price).toLocaleString() %><span>/one-time</span></div>
                <div style="height: 1px; background: var(--glass-border); margin: 1rem 0;"></div>
                <ul>
                    <li><i class="fas fa-clock"></i> <%= plan.duration_seconds > 0 ? (plan.duration_seconds / 3600).toFixed(1) + ' Hours' : 'Unlimited' %> Access</li>
                    <li><i class="fas fa-database"></i> <%= plan.data_bytes > 0 ? (plan.data_bytes / (1024*1024*1024)).toFixed(1) + ' GB' : 'Unlimited' %> Data</li>
                    <li><i class="fas fa-check-circle"></i> High-Speed Connectivity</li>
                </ul>
                <button class="btn btn-primary buy-plan" data-plan-id="<%= plan.id %>" style="background: linear-gradient(45deg, var(--accent), #0891b2);">BUY VOUCHER</button>
            </div>
        <% }); %>
    </div>
</section>

<div id="paymentModal" class="modal">
    <div class="modal-content">
        <span class="close">&times;</span>
        <h2>Complete Purchase</h2>
        <form id="paymentForm">
            <input type="hidden" id="selectedPlanId">
            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" placeholder="email@example.com" required>
            </div>
            <button type="submit" class="btn btn-primary btn-block">Pay with Paystack</button>
        </form>
    </div>
</div>
