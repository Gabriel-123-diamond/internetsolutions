<section class="portal-hero">
    <h1>Welcome to Internet Solutions</h1>
    <p>Please enter your voucher code to start browsing.</p>
</section>

<section class="login-section">
    <div class="card">
        <h2><i class="fas fa-key"></i> Voucher Login</h2>
        <form action="/login/voucher" method="POST">
            <div class="form-group">
                <label for="voucherCode">Voucher Code</label>
                <input type="text" id="voucherCode" name="voucherCode" placeholder="Enter 6-character code" maxlength="6" required>
            </div>
            <button type="submit" class="btn btn-primary btn-block">Connect Now</button>
        </form>
        <p style="margin-top: 1rem;">Or <a href="/login">Login to your account</a></p>
    </div>
</section>

<section class="admin-entry">
    <a href="/admin/login" class="btn btn-primary"><i class="fas fa-user-shield"></i> Admin Access</a>
</section>

<section class="plans-section">
    <h2><i class="fas fa-wifi"></i> Purchase a Plan</h2>
    <p>Don't have a voucher? Choose a plan below.</p>
    
    <div class="plans-grid" id="plansGrid">
        <% plans.forEach(plan => { %>
            <div class="plan-card">
                <h3><%= plan.name %></h3>
                <div class="price">₦<%= parseFloat(plan.price).toLocaleString() %></div>
                <ul>
                    <li><%= plan.duration_seconds > 0 ? (plan.duration_seconds / 3600).toFixed(1) + ' Hours' : 'Unlimited' %> Access</li>
                    <li><%= plan.data_bytes > 0 ? (plan.data_bytes / (1024*1024*1024)).toFixed(1) + ' GB' : 'Unlimited' %> Data</li>
                </ul>
                <button class="btn btn-success buy-plan" data-plan-id="<%= plan.id %>">Buy Now</button>
            </div>
        <% }); %>
        <% if (plans.length === 0) { %>
            <p>No plans available at the moment.</p>
        <% } %>
    </div>
</section>

<div id="paymentModal" class="modal">
    <div class="modal-content">
        <span class="close">&times;</span>
        <h2>Complete Purchase</h2>
        <form id="paymentForm">
            <input type="hidden" id="selectedPlanId">
            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" placeholder="email@example.com" required>
            </div>
            <button type="submit" class="btn btn-primary btn-block">Pay with Paystack</button>
        </form>
    </div>
</div>
