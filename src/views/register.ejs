<div class="card">
    <h2><i class="fas fa-user-plus"></i> Create an Account</h2>
    <p>Register to track your vouchers and usage history.</p>
    
    <form action="/register" method="POST" style="margin-top: 2rem;">
        <div class="form-group">
            <label for="reg-email">Email Address</label>
            <input type="email" id="reg-email" name="email" required>
        </div>
        <div class="form-group">
            <label for="reg-password">Password</label>
            <div class="password-wrapper">
                <input type="password" id="reg-password" name="password" required>
                <i class="fas fa-eye toggle-password"></i>
            </div>
        </div>
        <button type="submit" class="btn btn-primary btn-block">Register</button>
    </form>
    
    <p style="margin-top: 1.5rem;">Already have an account? <a href="/login">Login here</a></p>
</div>
