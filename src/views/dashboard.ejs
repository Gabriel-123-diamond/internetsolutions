<div class="dashboard-grid">
    <div class="card">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <h2><i class="fas fa-tachometer-alt"></i> Dashboard</h2>
            <a href="/settings" class="btn btn-primary"><i class="fas fa-user-cog"></i> Settings</a>
        </div>
        <p>Welcome back! Here is your current status.</p>
        
        <div class="metrics-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1.5rem;">
            <div style="background: var(--bg); padding: 1rem; border-radius: var(--radius);">
                <p>Active Vouchers</p>
                <h3 style="color: var(--primary);">0</h3>
            </div>
            <div style="background: var(--bg); padding: 1rem; border-radius: var(--radius);">
                <p>Remaining Time</p>
                <h3 style="color: var(--success);">0m</h3>
            </div>
        </div>
    </div>

    <div class="card">
        <h3>My Vouchers</h3>
        <div class="table-responsive no-scrollbar">
            <table style="width: 100%; border-collapse: collapse; margin-top: 1rem; text-align: left;">
                <thead>
                    <tr style="border-bottom: 2px solid var(--border);">
                        <th style="padding: 0.5rem;">Code</th>
                        <th style="padding: 0.5rem;">Status</th>
                        <th style="padding: 0.5rem;">Plan</th>
                        <th style="padding: 0.5rem;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (vouchers && vouchers.length > 0) { %>
                        <% vouchers.forEach(v => { %>
                            <tr style="border-bottom: 1px solid var(--border);">
                                <td style="padding: 0.75rem;"><code style="font-weight: bold; background: #f1f5f9; padding: 2px 4px; border-radius: 4px;"><%= v.username %></code></td>
                                <td style="padding: 0.75rem;"><span class="badge badge-<%= v.status %>"><%= v.status.toUpperCase() %></span></td>
                                <td style="padding: 0.75rem;"><%= v.plan_name %></td>
                                <td style="padding: 0.75rem;">
                                    <% if (v.status === 'active') { %>
                                        <button class="btn btn-danger pause-session" data-id="<%= v.id %>" data-mac="<%= v.last_mac_address %>" style="padding: 0.25rem 0.5rem; font-size: 0.8rem;">
                                            <i class="fas fa-pause"></i> Pause
                                        </button>
                                    <% } else { %>
                                        <span style="color: var(--text-muted); font-size: 0.8rem;">-</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" style="padding: 1rem; text-align: center; color: var(--text-muted);">No vouchers found.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>
